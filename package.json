{
  "name": "pi-cicd",
  "version": "1.0.15",
  "description": "Extension for Pi coding agent",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    }
  },
  "files": [
    "*.ts",
    "*.mjs",
    "src/**/*.ts",
    "README.md",
    "docs/",
    "skills/",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "pi",
    "coding-agent",
    "extension"
  ],
  "author": "BaphuongNA",
  "license": "MIT",
  "repository": "https://github.com/baphuongna/pi-cicd",
  "peerDependencies": {
    "typescript": "^5.0.0",
    "@earendil-works/pi-coding-agent": ">=0.73.0"
  },
  "scripts": {
    "postinstall": "node install.mjs"
  }
}
